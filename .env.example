# Copy to .env and fill in. .env is gitignored.

# Database
DB_PASSWORD=muntaspec
DATABASE_URL=postgresql://muntaspec:muntaspec@localhost:5432/muntaspec

# Auth (legacy MUNTec — keep for now, generate a random string)
JWT_SECRET=replace-with-32-byte-random-string

# CORS
CORS_ORIGINS=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000

# Decarb agent stack
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...    # for embeddings only — Anthropic embeddings are also fine

# Models
DECARB_MODEL=claude-sonnet-4-6
DECARB_EMBEDDING_MODEL=text-embedding-3-large
DECARB_EMBEDDING_DIM=3072

# Spend caps (£) — script will refuse to run if exceeded
DECARB_DAILY_LLM_BUDGET_GBP=20
DECARB_TOTAL_LLM_BUDGET_GBP=200
